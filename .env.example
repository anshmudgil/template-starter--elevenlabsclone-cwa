# Clerk Authentication (required for build)
# Create an application at https://dashboard.clerk.com and add your keys here.
# Copy this file to .env and fill in the values.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk JWT template for Supabase (name must be "supabase") — see:
# https://supabase.com/docs/guides/auth/third-party/clerk
# Enable the Clerk third-party auth integration in the Supabase dashboard.

# Supabase (Mission Control data + realtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL (for redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
